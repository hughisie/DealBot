{
  "name": "01.-distibot",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE NODE_ENV=development electron .",
    "build": "cd frontend && npm run build && cd .. && electron-builder",
    "postinstall": "cd frontend && npm install && cd ../backend && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.distibot.app",
    "productName": "DistiBot",
    "mac": {
      "category": "public.app-category.news"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      ".env",
      "backend/**/*",
      "frontend/dist/**/*"
    ],
    "extends": null
  }
}